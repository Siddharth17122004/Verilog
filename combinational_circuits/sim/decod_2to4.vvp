    %store/vec4 v0x62bf75294510_0, 0, 4;
    %jmp T_0.1;
T_0.0 ;
    %pushi/vec4 1, 0, 4;
    %ix/getv 4, v0x62bf7527add0_0;
    %shiftl 4;
    %store/vec4 v0x62bf75294510_0, 0, 4;
T_0.1 ;
