    .port_info 2 /OUTPUT 8 "Y";
v0x62bf752948c0_0 .net "A", 2 0, v0x62bf75294ce0_0;  1 drivers
v0x62bf752949c0_0 .net "EN", 0 0, v0x62bf75294eb0_0;  1 drivers
v0x62bf75294a80_0 .var "Y", 7 0;
E_0x62bf75242050 .event anyedge, v0x62bf752949c0_0, v0x62bf752948c0_0;
    .scope S_0x62bf7527aba0;
T_0 ;
    %wait E_0x62bf75241d20;
    %load/vec4 v0x62bf75294450_0;
    %nor/r;
    %flag_set/vec4 8;
