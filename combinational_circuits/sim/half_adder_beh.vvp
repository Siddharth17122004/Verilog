    %vpi_call 2 11 "$dumpvars", 32'sb00000000000000000000000000000000, S_0x58a326ac4a10 {0 0 0};
    %vpi_call 2 12 "$display", "HALF ADDER BEHAVIOR OUTPUT" {0 0 0};
    %vpi_call 2 13 "$monitor", "a=%b b=%b sum=%b cout=%b", v0x58a326ad83d0_0, v0x58a326ad8490_0, v0x58a326ad8660_0, v0x58a326ad8560_0 {0 0 0};
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x58a326ad83d0_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x58a326ad8490_0, 0, 1;
    %delay 10000, 0;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x58a326ad83d0_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x58a326ad8490_0, 0, 1;
    %delay 10000, 0;
