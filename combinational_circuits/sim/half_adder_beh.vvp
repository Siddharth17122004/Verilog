    %load/vec4 v0x58a326ad8100_0;
    %and;
    %store/vec4 v0x58a326ad81c0_0, 0, 1;
    %jmp T_0;
    .thread T_0, $push;
    .scope S_0x58a326ac4a10;
T_1 ;
