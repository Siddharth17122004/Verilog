    %assign/vec4 v0x595c52ad3670_0, 0;
    %jmp T_0.1;
T_0.0 ;
    %load/vec4 v0x595c52ad3670_0;
    %parti/s 3, 0, 2;
    %load/vec4 v0x595c52ad3820_0;
    %concat/vec4; draw_concat_vec4
    %assign/vec4 v0x595c52ad3670_0, 0;
T_0.1 ;
    %jmp T_0;
