    %store/vec4 v0x595c52ad3b20_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x595c52ad3c20_0, 0, 1;
    %delay 10000, 0;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x595c52ad3c20_0, 0, 1;
    %delay 10000, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x595c52ad3c20_0, 0, 1;
    %delay 10000, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x595c52ad3c20_0, 0, 1;
