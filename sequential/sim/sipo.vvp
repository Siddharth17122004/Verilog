    .scope S_0x595c52ac0f80;
T_3 ;
    %vpi_call 2 14 "$dumpfile", "sipo.vcd" {0 0 0};
    %vpi_call 2 15 "$dumpvars", 32'sb00000000000000000000000000000000, S_0x595c52ac0f80 {0 0 0};
    %pushi/vec4 1, 0, 1;
